# Temper Configuration

# Stack: auto-detect from project files
# Override: spring-boot, react-ts, node-express, fastapi, go, rust
stack: auto

# Enabled packs (loaded during review)
packs:
  - quality
  - tdd
  - security
  - git
  # - company

# Review settings
review:
  block-on: [critical]
  auto-fix: true
  confidence-threshold: 0.7

# Check settings
check:
  coverage-threshold: 80
  debt-tracking: true

# Branch conventions
branch:
  pattern: "feature/{ticket}-{description}"
  commit-style: conventional
